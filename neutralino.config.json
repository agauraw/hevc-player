{
  "applicationId": "com.gauraw.agplayer",
  "version": "1.0.0",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "none",
  "logging": {
    "enabled": false
  },
  "modes": {
    "window": {
      "title": "AGPlayer — HEVC · CMAF · DRM",
      "url": "/index.html",
      "width": 1400,
      "height": 860,
      "minWidth": 900,
      "minHeight": 600,
      "fullScreen": false,
      "alwaysOnTop": false,
      "enableInspector": false,
      "borderless": true,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "AGPlayer",
    "resourcesPath": "/renderer/",
    "extensionsPath": "/extensions/",
    "defaultMode": "window",
    "frontendLibrary": {
      "patchFile": "/renderer/index.html",
      "devUrl": ""
    },
    "binaryVersion": "6.8.0"
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "window.*",
    "filesystem.*"
  ]
}