{
  "name": "gauraw-player",
  "version": "1.0.0",
  "description": "Gauraw — HEVC/CMAF desktop player with Widevine DRM",
  "author": {
    "name": "Gauraw",
    "email": "gauraw2004amit@gmail.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "setup": "node scripts/setup-build.js",
    "build": "npm run setup && electron-builder --win",
    "build:dir": "npm run setup && electron-builder --win --dir",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "hls.js": "^1.6.16",
    "shaka-player": "^4.14.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gauraw.agplayer",
    "productName": "AGPlayer",
    "copyright": "Copyright © 2026 Gauraw. All rights reserved.",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "AGPlayer-Setup-${version}.exe",
      "shortcutName": "AGPlayer"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "node_modules/shaka-player/dist/shaka-player.compiled.js",
      "assets/**"
    ]
  }
}
